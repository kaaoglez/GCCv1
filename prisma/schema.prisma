generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../db/custom.db"
}

model Article {
  id          String    @id
  slug        String    @unique
  title       String
  content     String
  excerpt     String?
  authorId    String
  category    String    @default("GENERAL")
  image       String?
  tags        String?   @default("[]")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id])

  @@index([isPublished, publishedAt])
}

model Category {
  id             String     @id
  slug           String     @unique
  nameEs         String
  nameEn         String
  descEs         String?
  descEn         String?
  icon           String     @default("circle")
  color          String     @default("#52B788")
  parentId       String?
  sortOrder      Int        @default(0)
  isActive       Boolean    @default(true)
  isPaid         Boolean    @default(false)
  price          Float?
  highlightPrice Float?     @default(5)
  vipPrice       Float?     @default(15)
  allowedFields  String?    @default("[]")
  showPrice      Boolean    @default(true)
  showLocation   Boolean    @default(true)
  showImages     Boolean    @default(true)
  maxImages      Int        @default(5)
  expiryDays     Int        @default(30)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  parent         Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children       Category[] @relation("CategoryToCategory")
  listings       Listing[]

  @@index([isActive, sortOrder])
  @@index([parentId, sortOrder])
}

model CommunityStat {
  id        String   @id
  statKey   String   @unique
  statValue Float
  statLabel String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Event {
  id           String    @id
  slug         String    @unique
  title        String
  description  String
  authorId     String
  startDate    DateTime
  endDate      DateTime?
  allDay       Boolean   @default(false)
  recurring    String?
  location     String
  municipality String
  lat          Float?
  lng          Float?
  image        String?
  category     String    @default("OTHER")
  isFree       Boolean   @default(true)
  price        Float?
  ticketUrl    String?
  capacity     Int?
  organizer    String?
  contactEmail String?
  contactPhone String?
  website      String?
  isEco        Boolean   @default(false)
  ecoTags      String?
  status       String    @default("UPCOMING")
  viewCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  author       User      @relation(fields: [authorId], references: [id])

  @@index([municipality])
  @@index([status, startDate])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
  @@index([userId])
}

model Listing {
  id            String     @id
  slug          String     @unique
  title         String
  description   String
  categoryId    String
  authorId      String
  tier          String     @default("FREE")
  metadata      String     @default("{}")
  images        String     @default("[]")
  municipality  String?
  location      String?
  lat           Float?
  lng           Float?
  status        String     @default("DRAFT")
  expiresAt     DateTime?
  bumpedAt      DateTime?
  publishedAt   DateTime?
  viewCount     Int        @default(0)
  contactCount  Int        @default(0)
  showPhone     Boolean    @default(false)
  showEmail     Boolean    @default(true)
  contactMethod String     @default("message")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  favorites     Favorite[]
  author        User       @relation(fields: [authorId], references: [id])
  category      Category   @relation(fields: [categoryId], references: [id])
  messages      Message[]
  payment       Payment?

  @@index([tier])
  @@index([municipality, status])
  @@index([authorId])
  @@index([categoryId, status])
  @@index([status, createdAt])
}

model Message {
  id                            String   @id
  listingId                     String?
  senderId                      String
  receiverId                    String
  subject                       String
  content                       String
  isRead                        Boolean  @default(false)
  createdAt                     DateTime @default(now())
  listing                       Listing? @relation(fields: [listingId], references: [id])
  receiver                      User     @relation("Message_receiverIdToUser", fields: [receiverId], references: [id])
  sender                        User     @relation("Message_senderIdToUser", fields: [senderId], references: [id])

  @@index([listingId])
  @@index([receiverId])
  @@index([senderId])
}

model Payment {
  id           String    @id
  userId       String
  listingId    String?   @unique
  flyerId      String?   @unique
  type         String
  amount       Float
  status       String    @default("PENDING")
  provider     String?
  providerId   String?
  providerData String?
  validFrom    DateTime  @default(now())
  validUntil   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  listing      Listing?  @relation(fields: [listingId], references: [id])
  flyer        Flyer?    @relation(fields: [flyerId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([flyerId])
}

model Flyer {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  description   String?
  businessName  String
  businessPhone String?
  businessEmail String?
  businessWebsite String?
  businessAddress String?
  municipality  String?
  category      String    @default("SUPERMARKET")
  image         String
  thumbnail     String?
  validFrom     DateTime  @default(now())
  validUntil    DateTime?
  tier          String    @default("BASIC")
  status        String    @default("ACTIVE")
  viewCount     Int       @default(0)
  clickCount    Int       @default(0)
  authorId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        User      @relation("UserFlyers", fields: [authorId], references: [id])
  payment       Payment?

  @@index([municipality])
  @@index([category, status])
  @@index([validFrom, validUntil])
  @@index([tier, status])
  @@index([authorId])
}

model FlyerPlan {
  id             String   @id @default(cuid())
  tier           String   @unique
  nameEs         String
  nameEn         String
  price          Float    @default(0)
  priceLabelEs   String
  priceLabelEn   String
  badgeEs        String
  badgeEn        String
  color          String   @default("#6B7280")
  featuresEs     String   @default("[]")
  featuresEn     String   @default("[]")
  flyersPerWeek  Int      @default(1)
  isPopular      Boolean  @default(false)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AdBanner {
  id            String    @id @default(cuid())
  position      String    // leaderboard, sidebar, news, directory, between_sections
  title         String?
  imageUrl      String
  linkUrl       String?
  altText       String?
  businessName  String?
  businessEmail String?
  businessPhone String?
  businessSite  String?
  description   String?
  width         Int?
  height        Int?
  active        Boolean   @default(true)
  sortOrder     Int       @default(0)
  clicks        Int       @default(0)
  impressions   Int       @default(0)
  validFrom     DateTime  @default(now())
  validUntil    DateTime?
  paymentId     String?
  userId        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([position, active, sortOrder])
  @@index([validFrom, validUntil])
  @@index([userId])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model RecyclingPoint {
  id           String   @id
  name         String
  description  String?
  address      String
  municipality String
  lat          Float?
  lng          Float?
  types        String   @default("[]")
  schedule     String?
  phone        String?
  website      String?
  email        String?
  facilityType String   @default("ecoparque")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id                               String     @id
  email                            String     @unique
  password                         String?
  name                             String
  avatar                           String?
  phone                            String?
  bio                              String?
  municipality                     String?
  role                             String     @default("MEMBER")
  language                         String     @default("ES")
  isVerified                       Boolean    @default(false)
  isActive                         Boolean    @default(true)
  createdAt                        DateTime   @default(now())
  updatedAt                        DateTime   @updatedAt
  businessName                     String?
  businessDescription              String?
  businessAddress                  String?
  businessPhone                    String?
  businessWebsite                  String?
  businessHours                    String?
  businessLogo                     String?
  businessCategory                 String?
  planExpiresAt                    DateTime?
  articles                         Article[]
  events                           Event[]
  favorites                        Favorite[]
  listings                         Listing[]
  receivedMessages                 Message[]  @relation("Message_receiverIdToUser")
  sentMessages                     Message[]  @relation("Message_senderIdToUser")
  payments                         Payment[]
  flyers                           Flyer[]    @relation("UserFlyers")
}
